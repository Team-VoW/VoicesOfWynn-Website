<?php
// Variables expected from the including file:
// $cardNpc            - NPC object
// $cardQuestNames     - array($questId => $questName)
// $cardRecordingsByQuest - array($questId => $recordings[])
// $cardAllRecordings  - flat array of all recordings
// $cardIsUpvoted      - bool
// $cardIsDownvoted    - bool
// $cardIsOpen         - bool (default false)
// $cardAdmin          - bool (default false)
// $cardNpcId          - int
$cardIsOpen = $cardIsOpen ?? false;
$cardAdmin = $cardAdmin ?? false;
?>
<div class="cast-npc-block recording-actions<?= $cardIsOpen ? ' is-open' : '' ?>">
    <div class="cast-npc-header">
        <button class="cast-npc-toggle" aria-expanded="<?= $cardIsOpen ? 'true' : 'false' ?>">
            <img
                class="cast-npc-pic"
                src="<?= \VoicesOfWynn\storageUrl('npcs/' . $cardNpc->getId() . '.png') ?>"
                alt="<?= htmlspecialchars($cardNpc->getName()) ?>"
                loading="lazy"
            />
            <div class="cast-npc-info">
                <span class="cast-npc-block-name">
                    <?= $cardNpc->getName() ?>
                    <?php if ($cardNpc->isArchived()): ?>
                        <span class="cast-archived-badge">Outdated</span>
                    <?php endif ?>
                </span>
                <span class="cast-npc-meta">
                    in <?= implode(', ', $cardQuestNames) ?>
                    &bull; <?= count($cardAllRecordings) ?> recording<?= count($cardAllRecordings) !== 1 ? 's' : '' ?>
                </span>
            </div>
        </button>
        <div class="cast-npc-actions">
            <button class="vote-btn upvote-btn upvote<?= $cardIsUpvoted ? ' clicked' : '' ?>" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">👍</span>
                <span class="vote-count"><?= $cardNpc->getUpvotes() ?></span>
            </button>
            <button class="vote-btn downvote-btn downvote<?= $cardIsDownvoted ? ' clicked' : '' ?>" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">👎</span>
                <span class="vote-count"><?= $cardNpc->getDownvotes() ?></span>
            </button>
            <button class="vote-btn comment-btn comment" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">💬</span>
                <span class="vote-count"><?= $cardNpc->getCommentsCount() ?></span>
            </button>
            <svg class="cast-npc-chevron" aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
    </div>

    <div class="cast-npc-recordings">
        <?php if (count($cardQuestNames) === 1): ?>
            <div class="cast-quest-grid">
                <?php foreach ($cardAllRecordings as $recording): ?>
                    <div class="cast-recording-item">
                        <div class="cast-recording-line">
                            <span class="line-number"># <?= $recording->line ?></span>
                        </div>
                        <div class="cast-recording-player">
                            <?php $audioSrc = \VoicesOfWynn\storageUrl('recordings/' . $recording->file); ?>
                            <?php include 'Views/partials/audio-player.phtml'; ?>
                        </div>
                        <?php if ($cardAdmin): ?>
                            <button class="delete-recording-btn" data-recording-id="<?= $recording->id ?>">×</button>
                        <?php endif ?>
                    </div>
                <?php endforeach ?>
            </div>
            <?php if ($cardAdmin): ?>
                <?php $questId = array_key_first($cardQuestNames); ?>
                <div class="quest-admin-actions">
                    <button class="archive-all-recordings-btn" data-quest-id="<?= $questId ?>">Archive all recordings</button>
                    <a href="/administration/upload?questId=<?= $questId ?>&amp;npcId=<?= $cardNpcId ?>" class="uploadbtn">Add new recordings</a>
                </div>
            <?php endif ?>
        <?php else: ?>
            <?php foreach ($cardRecordingsByQuest as $questId => $questRecordings): ?>
                <div class="cast-quest-section">
                    <h4 class="cast-quest-label"><?= $cardQuestNames[$questId] ?></h4>
                    <div class="cast-quest-grid">
                        <?php foreach ($questRecordings as $recording): ?>
                            <div class="cast-recording-item">
                                <div class="cast-recording-line">
                                    <span class="line-number"># <?= $recording->line ?></span>
                                </div>
                                <div class="cast-recording-player">
                                    <?php $audioSrc = \VoicesOfWynn\storageUrl('recordings/' . $recording->file); ?>
                                    <?php include 'Views/partials/audio-player.phtml'; ?>
                                </div>
                                <?php if ($cardAdmin): ?>
                                    <button class="delete-recording-btn" data-recording-id="<?= $recording->id ?>">×</button>
                                <?php endif ?>
                            </div>
                        <?php endforeach ?>
                    </div>
                    <?php if ($cardAdmin): ?>
                        <div class="quest-admin-actions">
                            <button class="archive-all-recordings-btn" data-quest-id="<?= $questId ?>">Archive all recordings</button>
                            <a href="/administration/upload?questId=<?= $questId ?>&amp;npcId=<?= $cardNpcId ?>" class="uploadbtn">Add new recordings</a>
                        </div>
                    <?php endif ?>
                </div>
            <?php endforeach ?>
        <?php endif ?>
    </div>
</div>
