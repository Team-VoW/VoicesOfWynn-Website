<?php
// Variables expected from the including file:
// $cardNpc            - NPC object
// $cardQuestNames     - array($questId => $questName)
// $cardQuestDegeneratedNames - array($questId => $degeneratedName)
// $cardRecordingsByQuest - array($questId => $recordings[])
// $cardAllRecordings  - flat array of all recordings
// $cardIsUpvoted      - bool
// $cardIsDownvoted    - bool
// $cardIsOpen         - bool (default false)
// $cardAdmin          - bool (default false)
// $cardNpcId          - int
$cardIsOpen = $cardIsOpen ?? false;
$cardAdmin = $cardAdmin ?? false;
$cardShowFeaturedRecording = $cardShowFeaturedRecording ?? false;
$cardShowQuestNames        = $cardShowQuestNames        ?? true;
$cardShowVoiceActor        = $cardShowVoiceActor        ?? true;
$cardShowSoundEditor       = $cardShowSoundEditor       ?? false;
$cardQuestForSoundEditor   = $cardQuestForSoundEditor   ?? null;
?>
<div class="cast-npc-block recording-actions<?= $cardIsOpen ? ' is-open' : '' ?>">
    <div class="cast-npc-header" role="button" tabindex="0" aria-expanded="<?= $cardIsOpen ? 'true' : 'false' ?>">
        <div class="cast-npc-toggle">
            <a href="contents/npc/<?= $cardNpc->getId() ?>" class="cast-npc-link cast-npc-link--pic">
                <img
                    class="cast-npc-pic"
                    src="<?= \VoicesOfWynn\storageUrl('npcs/' . $cardNpc->getId() . '.webp') ?>"
                    onerror="this.onerror=null; this.src='<?= \VoicesOfWynn\storageUrl('npcs/default.webp') ?>'"
                    alt="<?= htmlspecialchars($cardNpc->getName()) ?>"
                    loading="lazy"
                />
            </a>
            <div class="cast-npc-info">
                <div>
                    <a href="contents/npc/<?= $cardNpc->getId() ?>" class="cast-npc-link cast-npc-link--name cast-npc-block-name">
                        <?= $cardNpc->getName() ?>
                        <?php if ($cardNpc->isArchived()): ?>
                            <span class="cast-archived-badge">Outdated</span>
                        <?php endif ?>
                    </a>
                </div>
                <?php if ($cardShowQuestNames): ?>
                <span class="cast-npc-meta">
                    in <?= implode(', ', array_map(fn($id, $name) => '<a href="contents/' . ($cardQuestDegeneratedNames[$id] ?? $id) . '" class="cast-quest-link">' . $name . '</a>', array_keys($cardQuestNames), $cardQuestNames)) ?>
                    &bull; <?= count($cardAllRecordings) ?> recording<?= count($cardAllRecordings) !== 1 ? 's' : '' ?>
                </span>
                <?php endif ?>
            </div>
        </div>
        <?php if ($cardShowFeaturedRecording): ?>
            <div class="cast-npc-featured-audio">
                <?php $featuredRecording = $cardAllRecordings[0] ?? null; ?>
                <?php if ($featuredRecording !== null): ?>
                    <?php $audioSrc = \VoicesOfWynn\storageUrl('recordings/' . $featuredRecording->file); ?>
                    <?php include 'Views/partials/audio-player.phtml'; ?>
                <?php endif ?>
            </div>
            <?php if ($cardShowVoiceActor): ?>
            <div class="cast-npc-featured-va">
                <?php $va = $cardNpc->getVoiceActor(); ?>
                <?php if ($va === null): ?>
                    <i class="cast-npc-va-name">Nobody</i>
                    <img class="cast-npc-va-avatar" src="<?= \VoicesOfWynn\storageUrl('avatars/nobody.png') ?>" alt="Profile picture" />
                <?php else: ?>
                    <a href="cast/<?= $va->getId() ?>" class="cast-npc-va-name"><?= $va->getName() ?></a>
                    <a href="cast/<?= $va->getId() ?>" class="cast-npc-va-link--pic">
                        <img class="cast-npc-va-avatar" src="<?= \VoicesOfWynn\storageUrl('avatars/' . $va->getAvatar()) ?>" alt="Profile picture" />
                    </a>
                <?php endif ?>
            </div>
            <?php endif ?>
        <?php endif ?>
        <div class="cast-npc-actions">
            <button class="vote-btn upvote-btn upvote<?= $cardIsUpvoted ? ' clicked' : '' ?>" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">👍</span>
                <span class="vote-count"><?= $cardNpc->getUpvotes() ?></span>
            </button>
            <button class="vote-btn downvote-btn downvote<?= $cardIsDownvoted ? ' clicked' : '' ?>" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">👎</span>
                <span class="vote-count"><?= $cardNpc->getDownvotes() ?></span>
            </button>
            <button class="vote-btn comment-btn comment" data-npc-id="<?= $cardNpcId ?>">
                <span class="vote-icon">💬</span>
                <span class="vote-count"><?= $cardNpc->getCommentsCount() ?></span>
            </button>
            <svg class="cast-npc-chevron" aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
    </div>

    <div class="cast-npc-recordings">
        <?php $multipleQuests = count($cardQuestNames) > 1; ?>
        <?php foreach ($cardRecordingsByQuest as $questId => $questRecordings): ?>
            <?php if ($multipleQuests): ?>
                <div class="cast-quest-section">
                    <h4 class="cast-quest-label"><a href="contents/<?= $cardQuestDegeneratedNames[$questId] ?>" class="cast-quest-link"><?= $cardQuestNames[$questId] ?></a></h4>
            <?php endif ?>
            <div class="cast-quest-grid">
                <?php foreach ($questRecordings as $recording): ?>
                    <div class="cast-recording-item">
                        <div class="cast-recording-line">
                            <span class="line-number"># <?= $recording->line ?></span>
                        </div>
                        <div class="cast-recording-player">
                            <?php $audioSrc = \VoicesOfWynn\storageUrl('recordings/' . $recording->file); ?>
                            <?php include 'Views/partials/audio-player.phtml'; ?>
                        </div>
                        <?php if ($cardAdmin): ?>
                            <button class="delete-recording-btn" data-recording-id="<?= $recording->id ?>">×</button>
                        <?php endif ?>
                    </div>
                <?php endforeach ?>
            </div>
            <?php if ($cardAdmin): ?>
                <div class="quest-admin-actions">
                    <button class="archive-all-recordings-btn" data-quest-id="<?= $questId ?>">Archive all recordings</button>
                    <a href="/administration/upload?questId=<?= $questId ?>&amp;npcId=<?= $cardNpcId ?>" class="uploadbtn">Add new recordings</a>
                </div>
            <?php endif ?>
            <?php if (!$multipleQuests && $cardShowSoundEditor):
                  $allSe = $cardNpc->getSoundEditor();
                  $se = $cardQuestForSoundEditor !== null
                      ? $cardNpc->getSoundEditor($cardQuestForSoundEditor)
                      : (is_array($allSe) ? reset($allSe) : $allSe);
                  if ($se !== null): ?>
            <div class="cast-npc-se-row">
                <span class="cast-npc-se-label">Edited by</span>
                <a href="/cast/<?= $se->getId() ?>" class="cast-npc-se-link--pic">
                    <img class="cast-npc-se-avatar"
                         src="<?= \VoicesOfWynn\storageUrl('avatars/' . $se->getAvatar()) ?>"
                         onerror="this.onerror=null; this.src='<?= \VoicesOfWynn\storageUrl('avatars/default.png') ?>'"
                         alt="Profile picture" loading="lazy" />
                </a>
                <a href="/cast/<?= $se->getId() ?>" class="cast-npc-se-name">
                    <?= htmlspecialchars($se->getName()) ?>
                </a>
            </div>
            <?php endif; endif ?>
            <?php if ($multipleQuests):
                  $allSoundEditors = $cardNpc->getSoundEditor();
                  $se = $cardShowSoundEditor && is_array($allSoundEditors) ? ($allSoundEditors[$questId] ?? null) : null;
                  if ($se !== null): ?>
                <div class="cast-npc-se-row">
                    <span class="cast-npc-se-label">Edited by</span>
                    <a href="/cast/<?= $se->getId() ?>" class="cast-npc-se-link--pic">
                        <img class="cast-npc-se-avatar"
                             src="<?= \VoicesOfWynn\storageUrl('avatars/' . $se->getAvatar()) ?>"
                             onerror="this.onerror=null; this.src='<?= \VoicesOfWynn\storageUrl('avatars/default.png') ?>'"
                             alt="Profile picture" loading="lazy" />
                    </a>
                    <a href="/cast/<?= $se->getId() ?>" class="cast-npc-se-name">
                        <?= htmlspecialchars($se->getName()) ?>
                    </a>
                </div>
                <?php endif ?>
                </div>
            <?php endif ?>
        <?php endforeach ?>
    </div>
</div>
